<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Lab4Calculator" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <style name="CalcButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:backgroundTint">@color/btn_digit</item>
    </style>

    <style name="CalcButton.Dark">
        <item name="android:backgroundTint">@color/btn_dark</item>
    </style>

    <style name="CalcButton.Orange">
        <item name="android:backgroundTint">@color/btn_orange</item>
    </style>
</resources>
