<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1E"
    android:padding="8dp">

    <!-- Expression display -->
    <TextView
        android:id="@+id/tv_expression"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:minHeight="40dp"
        android:paddingHorizontal="8dp"
        android:textColor="#8E8E93"
        android:textSize="20sp"
        android:contentDescription="@string/cd_expression"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Result display -->
    <TextView
        android:id="@+id/tv_result"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="8dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:contentDescription="@string/cd_result"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_expression" />

    <!-- Row 1: AC  +/-  %  ÷ -->
    <Button android:id="@+id/btn_clear"
        style="@style/CalcButton.Dark"
        android:text="@string/btn_clear"
        android:contentDescription="@string/btn_clear"
        app:layout_constraintTop_toBottomOf="@id/tv_result"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_negate" />

    <Button android:id="@+id/btn_negate"
        style="@style/CalcButton.Dark"
        android:text="+/-"
        android:contentDescription="@string/btn_negate"
        app:layout_constraintTop_toBottomOf="@id/tv_result"
        app:layout_constraintStart_toEndOf="@id/btn_clear"
        app:layout_constraintEnd_toStartOf="@id/btn_percent" />

    <Button android:id="@+id/btn_percent"
        style="@style/CalcButton.Dark"
        android:text="%"
        android:contentDescription="@string/btn_percent"
        app:layout_constraintTop_toBottomOf="@id/tv_result"
        app:layout_constraintStart_toEndOf="@id/btn_negate"
        app:layout_constraintEnd_toStartOf="@id/btn_divide" />

    <Button android:id="@+id/btn_divide"
        style="@style/CalcButton.Orange"
        android:text="÷"
        android:contentDescription="@string/btn_divide"
        app:layout_constraintTop_toBottomOf="@id/tv_result"
        app:layout_constraintStart_toEndOf="@id/btn_percent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Row 2: 7  8  9  × -->
    <Button android:id="@+id/btn_7"
        style="@style/CalcButton"
        android:text="7"
        app:layout_constraintTop_toBottomOf="@id/btn_clear"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_8" />

    <Button android:id="@+id/btn_8"
        style="@style/CalcButton"
        android:text="8"
        app:layout_constraintTop_toBottomOf="@id/btn_clear"
        app:layout_constraintStart_toEndOf="@id/btn_7"
        app:layout_constraintEnd_toStartOf="@id/btn_9" />

    <Button android:id="@+id/btn_9"
        style="@style/CalcButton"
        android:text="9"
        app:layout_constraintTop_toBottomOf="@id/btn_clear"
        app:layout_constraintStart_toEndOf="@id/btn_8"
        app:layout_constraintEnd_toStartOf="@id/btn_multiply" />

    <Button android:id="@+id/btn_multiply"
        style="@style/CalcButton.Orange"
        android:text="×"
        android:contentDescription="@string/btn_multiply"
        app:layout_constraintTop_toBottomOf="@id/btn_clear"
        app:layout_constraintStart_toEndOf="@id/btn_9"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Row 3: 4  5  6  - -->
    <Button android:id="@+id/btn_4"
        style="@style/CalcButton"
        android:text="4"
        app:layout_constraintTop_toBottomOf="@id/btn_7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_5" />

    <Button android:id="@+id/btn_5"
        style="@style/CalcButton"
        android:text="5"
        app:layout_constraintTop_toBottomOf="@id/btn_7"
        app:layout_constraintStart_toEndOf="@id/btn_4"
        app:layout_constraintEnd_toStartOf="@id/btn_6" />

    <Button android:id="@+id/btn_6"
        style="@style/CalcButton"
        android:text="6"
        app:layout_constraintTop_toBottomOf="@id/btn_7"
        app:layout_constraintStart_toEndOf="@id/btn_5"
        app:layout_constraintEnd_toStartOf="@id/btn_minus" />

    <Button android:id="@+id/btn_minus"
        style="@style/CalcButton.Orange"
        android:text="-"
        android:contentDescription="@string/btn_minus"
        app:layout_constraintTop_toBottomOf="@id/btn_7"
        app:layout_constraintStart_toEndOf="@id/btn_6"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Row 4: 1  2  3  + -->
    <Button android:id="@+id/btn_1"
        style="@style/CalcButton"
        android:text="1"
        app:layout_constraintTop_toBottomOf="@id/btn_4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_2" />

    <Button android:id="@+id/btn_2"
        style="@style/CalcButton"
        android:text="2"
        app:layout_constraintTop_toBottomOf="@id/btn_4"
        app:layout_constraintStart_toEndOf="@id/btn_1"
        app:layout_constraintEnd_toStartOf="@id/btn_3" />

    <Button android:id="@+id/btn_3"
        style="@style/CalcButton"
        android:text="3"
        app:layout_constraintTop_toBottomOf="@id/btn_4"
        app:layout_constraintStart_toEndOf="@id/btn_2"
        app:layout_constraintEnd_toStartOf="@id/btn_plus" />

    <Button android:id="@+id/btn_plus"
        style="@style/CalcButton.Orange"
        android:text="+"
        android:contentDescription="@string/btn_plus"
        app:layout_constraintTop_toBottomOf="@id/btn_4"
        app:layout_constraintStart_toEndOf="@id/btn_3"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Row 5: 0(wide)  .  ⌫  = -->
    <Button android:id="@+id/btn_0"
        style="@style/CalcButton"
        android:text="0"
        app:layout_constraintTop_toBottomOf="@id/btn_1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_dot"
        app:layout_constraintBottom_toBottomOf="parent" />

    <Button android:id="@+id/btn_dot"
        style="@style/CalcButton"
        android:text="."
        android:contentDescription="@string/btn_dot"
        app:layout_constraintTop_toBottomOf="@id/btn_1"
        app:layout_constraintStart_toEndOf="@id/btn_0"
        app:layout_constraintEnd_toStartOf="@id/btn_backspace"
        app:layout_constraintBottom_toBottomOf="parent" />

    <Button android:id="@+id/btn_backspace"
        style="@style/CalcButton.Dark"
        android:text="⌫"
        android:contentDescription="@string/btn_backspace"
        app:layout_constraintTop_toBottomOf="@id/btn_1"
        app:layout_constraintStart_toEndOf="@id/btn_dot"
        app:layout_constraintEnd_toStartOf="@id/btn_equals"
        app:layout_constraintBottom_toBottomOf="parent" />

    <Button android:id="@+id/btn_equals"
        style="@style/CalcButton.Orange"
        android:text="="
        android:contentDescription="@string/btn_equals"
        app:layout_constraintTop_toBottomOf="@id/btn_1"
        app:layout_constraintStart_toEndOf="@id/btn_backspace"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
